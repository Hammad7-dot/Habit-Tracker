# App
ENV=development
DEBUG=true

# Database
# Dev (SQLite):
DATABASE_URL=sqlite:///./habit_tracker.db
# Production (PostgreSQL) example — Render injects this automatically when
# using render.yaml, with a postgres:// URL that config.py normalizes to
# postgresql:// for you:
# DATABASE_URL=postgresql://user:password@host:5432/habit_tracker

# JWT
# In production, set a real random value — get_settings() refuses to start
# with ENV=production and the default SECRET_KEY still in place.
SECRET_KEY=change_this_to_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS - comma separated list of allowed origins
# Production: set to your deployed frontend origin, e.g.
# CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500
